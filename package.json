{
  "name": "ghl-marketplace-app-template",
  "version": "1.0.0",
  "description": "A boilerplate for creating GHL marketplace apps",
  "main": "src/index.ts",
  "scripts": {
    "build": "npx tsc && cp -r ./src/prompts ./dist/prompts && npm run build-ui && mkdir -p ./dist/ui/dist && cp -r ./src/ui/dist ./dist/ui",
    "build-ui": "cd src/ui && npm i && npm run build && cd ../../",
    "start": "node dist/index.js",
    "dev": "npm run build-ui && ts-node-dev src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GoHighLevel/ghl-marketplace-app-template.git"
  },
  "keywords": [
    "boilerplate",
    "ghl"
  ],
  "author": "GHL",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/GoHighLevel/ghl-marketplace-app-template/issues"
  },
  "homepage": "https://github.com/GoHighLevel/ghl-marketplace-app-template#readme",
  "dependencies": {
    "@langchain/anthropic": "^1.3.19",
    "@langchain/core": "^1.1.27",
    "axios": "^1.5.1",
    "body-parser": "^1.20.2",
    "cors": "^2.8.6",
    "crypto-js": "^4.1.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "langchain": "^1.2.25",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "vue": "^3.3.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.1.2",
    "@types/express": "^4.17.18",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.8.2",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
